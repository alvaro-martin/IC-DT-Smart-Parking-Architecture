# =============================================================================
# IC2 Digital Twin - Environment Variables Template
# =============================================================================
# Copy this file to .env and replace sample values with your own:
#   cp .env.example .env
#
# NEVER commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# InfluxDB Configuration
# Used by: parking-reader/app.py
# -----------------------------------------------------------------------------
# URL of your InfluxDB instance
INFLUXDB_URL=http://localhost:8086/

# API token with read access to the parking bucket
INFLUXDB_TOKEN=your-influxdb-token-here

# InfluxDB organization name
INFLUXDB_ORG=your-organization

# Bucket containing parking sensor data
INFLUXDB_BUCKET=your-bucket-name

# -----------------------------------------------------------------------------
# Orion Context Broker
# Used by: parking-reader/app.py
# -----------------------------------------------------------------------------
# Internal Docker URL for Orion-LD entity updates
ORION_URL=http://orion:1026/ngsi-ld/v1/entities/

# -----------------------------------------------------------------------------
# Domain & Reverse Proxy
# Used by: grafana.yaml, monitor-cloud/monitor-grafana.yaml, nginx.conf
# NOTE: NGINX does NOT support environment variable substitution in config
#       files. You must manually replace 'server_name' in nginx.conf with
#       this value.
# -----------------------------------------------------------------------------
DOMAIN_NAME=localhost

# -----------------------------------------------------------------------------
# Grafana URLs (auto-derived from DOMAIN_NAME)
# Used by: grafana.yaml
# -----------------------------------------------------------------------------
GRAFANA_ROOT_URL=https://${DOMAIN_NAME}/grafana/

# Used by: monitor-cloud/monitor-grafana.yaml
MONITOR_GRAFANA_ROOT_URL=https://${DOMAIN_NAME}/monitor-grafana/

# -----------------------------------------------------------------------------
# LLM Configuration (Monte Carlo Simulation)
# Used by: simulation.yml, simulation/llm_client.py
# -----------------------------------------------------------------------------
API_KEY=your-llm-api-key-here
API_URL=https://your-llm-endpoint/api/chat/completions
LLM_MODEL=your-model-name
