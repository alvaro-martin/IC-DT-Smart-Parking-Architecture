# =============================================================================
# Fog Cluster - onCluster ML Service - Environment Variables
# =============================================================================
# Copy this file and fill in your real values:
#   cp .env.example .env
#
# NEVER commit .env to version control.
# =============================================================================

# IoT Agent endpoint on VM2 (include port and /iot/json path)
IOT_URL=http://<vm2-domain>:7896/iot/json

# API key for IoT Agent authentication
IOT_KEY=your-iot-agent-service-group-api-key

# Tailscale auth key (used by the tailscale sidecar service)
TS_AUTHKEY=tskey-auth-xxxxxxxxxxxx
