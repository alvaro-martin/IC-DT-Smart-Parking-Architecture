# =============================================================================
# Fog Deploy Configuration
# =============================================================================
# Copy this file and fill in your real values:
#   cp fog_deploy.conf.example fog_deploy.conf
#
# NEVER commit fog_deploy.conf to version control.
# =============================================================================

# Test parameters
M=136
N=30
seed=1
alpha=1
beta=1

# Cluster connection (Tailscale) - inference endpoint
Cluster_tailscale_domain_name="http://your-cluster-node.tailnet.ts.net"

# VM connection (Tailscale) - runs infra/
VM_tailscale_domain_name="http://your-vm-name.tailnet.ts.net"
VM_tailscale_IPv4="100.x.x.x"
VM_username="ubuntu"
VM_password="your-ssh-password"

# Directory paths
VM_dir="/home/ubuntu"
LM_dir="/home/your-user/Desktop"
onVM_dir="IC-DT-Smart-Parking-Architecture/fog_deploy/onVMScripts"
onGen_dir="IC-DT-Smart-Parking-Architecture/fog_deploy/onGenScripts"
onInfra_dir="IC-DT-Smart-Parking-Architecture/fog_deploy/infra"
