# =============================================================================
# Jetson ML Service - Environment Variables
# =============================================================================
# Copy this file and fill in your real values:
#   cp .env.example .env
#
# NEVER commit .env to version control.
# =============================================================================

# IoT Agent endpoint on VM1 (include port and /iot/json path)
IOT_URL=http://your-vm-domain:7896/iot/json

# API key for IoT Agent authentication
IOT_KEY=12345
